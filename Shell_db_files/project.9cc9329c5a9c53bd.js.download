:"Can access Salesforce information"},[l.GLOBAL_ATLAS_TSE]:{role:l.GLOBAL_ATLAS_TSE,label:"Global Atlas TSE",description:"Can generate requestID tokens for SSH access to an Atlas server"},[l.GLOBAL_ATLAS_AUTOMATED_OPERATOR]:{role:l.GLOBAL_ATLAS_AUTOMATED_OPERATOR,label:"Global Atlas Automated Operator",description:"Can perform safe cluster actions trusted as part of automations including critical reboots"},[l.GLOBAL_ATLAS_OPERATOR]:{role:l.GLOBAL_ATLAS_OPERATOR,label:"Global Atlas Operator",description:"Can use the admin UI to take actions on projects or clusters"},[l.GLOBAL_ATLAS_ADMIN]:{role:l.GLOBAL_ATLAS_ADMIN,label:"Global Atlas Admin",description:"Can administer global configuration for Atlas"},[l.GLOBAL_BAAS_INTERNAL_ADMIN]:{role:l.GLOBAL_BAAS_INTERNAL_ADMIN,label:"Global App Services Internal Admin",description:"Can administer specific internal App Services operations"},[l.GLOBAL_CCS_INTERNAL_ADMIN]:{role:l.GLOBAL_CCS_INTERNAL_ADMIN,label:"Global Cluster Connection Service Internal Admin",description:"Can administer specific internal Cluster Connection Service operations"},[l.GLOBAL_ATLAS_MCP_INTERNAL_ADMIN]:{role:l.GLOBAL_ATLAS_MCP_INTERNAL_ADMIN,label:"Global Atlas MCP Internal Admin",description:"Can administer specific internal Atlas MCP Service operations"},[l.GLOBAL_SECURITY_ADMIN]:{role:l.GLOBAL_SECURITY_ADMIN,label:"Global Security Admin",description:"Can access secure endpoints for logging users out"},[l.GLOBAL_PROACTIVE_SUPPORT_ADMIN]:{role:l.GLOBAL_PROACTIVE_SUPPORT_ADMIN,label:"Global Proactive Support Admin",description:"Can send support emails and manage messages"},[l.GLOBAL_LEGAL_ADMIN]:{role:l.GLOBAL_LEGAL_ADMIN,label:"Global Legal Admin",description:"Can clear users and projects from OFAC checks"},[l.GLOBAL_EXPERIMENT_ASSIGNMENT_ADMIN]:{role:l.GLOBAL_EXPERIMENT_ASSIGNMENT_ADMIN,label:"Global Experiment Assignment Admin",description:"Can request for entities to be allocated into AB Tests"},[l.GLOBAL_EXPERIMENT_OVERRIDE_ASSIGNMENT_ADMIN]:{role