_AUTOMATION_ADMIN]:{role:g.GROUP_AUTOMATION_ADMIN,label:"Project Automation Admin",description:"Can administer automation"},[g.GROUP_BACKUP_ADMIN]:{role:g.GROUP_BACKUP_ADMIN,label:"Project Backup Admin",description:"Can administer backups, and pull restores"},[g.GROUP_MONITORING_ADMIN]:{role:g.GROUP_MONITORING_ADMIN,label:"Project Monitoring Admin",description:"Can administer hosts and alerts"},[g.GROUP_USER_ADMIN]:{role:g.GROUP_USER_ADMIN,label:"Project User Admin",description:"Can administer users"},[g.GROUP_CLUSTER_MANAGER]:{role:g.GROUP_CLUSTER_MANAGER,label:"Project Cluster Manager",description:"Can update clusters",isAtlas:!0,atlasOnly:!0,sectionId:d.CLUSTER},[g.GROUP_DATA_ACCESS_ADMIN]:{role:g.GROUP_DATA_ACCESS_ADMIN,label:"Project Data Access Admin",description:"Can access and modify a cluster's data and indexes, and kill operations",isAtlas:!0,sectionId:d.DATA_ACCESS},[g.GROUP_DATA_ACCESS_READ_WRITE]:{role:g.GROUP_DATA_ACCESS_READ_WRITE,label:"Project Data Access Read/Write",description:"Can access a cluster's data and indexes, and modify data",isAtlas:!0,sectionId:d.DATA_ACCESS},[g.GROUP_DATA_ACCESS_READ_ONLY]:{role:g.GROUP_DATA_ACCESS_READ_ONLY,label:"Project Data Access Read Only",description:"Can access a cluster's data and indexes",isAtlas:!0,sectionId:d.DATA_ACCESS},[g.GROUP_READ_ONLY]:{role:g.GROUP_READ_ONLY,label:"Project Read Only",description:"May only modify personal preferences",isAtlas:!0,sectionId:d.BASIC},[g.GROUP_SEARCH_INDEX_EDITOR]:{role:g.GROUP_SEARCH_INDEX_EDITOR,label:"Project Search Index Editor",description:"Can view and manage a cluster's search indexes",isAtlas:!0,atlasOnly:!0,sectionId:d.SERVICE},[g.GROUP_STREAM_PROCESSING_OWNER]:{role:g.GROUP_STREAM_PROCESSING_OWNER,label:"Project Stream Processing Owner",description:"Has full administration access to stream processing instances including connection registry and stream processors. Can create DB Roles and Custom Roles.",isAtlas:!0,atlasOnly:!0,sectionId:d.SERVICE},[g.GROUP_BACKUP_MANAGER]:{role:g.GROUP_BACKUP_MANAGER,label:"Project Backup Manager",description:"Can manage, restore, and export backups",isAtlas:!0,atlasOnly:!0,sectionId:d.BACKUP},[g.GROUP_OBSERVABILITY_VIEWER]:{role:g.GROUP_OBSERVABILITY_VIEWER,label:"Project Observability Viewer",description:"Can access the Performance Advisor, Namespace Insights, Query Profiler, and Real-Time Performance Panel.",isAtlas:!0,atlasOnly:!0,sectionId:d.SERVICE},[g.GROUP_DATABASE_ACCESS_ADMIN]:{role:g.GROUP_DATABASE_ACCESS_ADMIN,label:"Project Database Access Admin",description:"Can view and manage database access",isAtlas:!0,atlasOnly:!0,sectionId:d.ACCESS_MANAGEMENT},[g.GROUP_CLUSTER_CREATOR]:{role:g.GROUP_CLUSTER_CREATOR,label:"Project Cluster Creator",description:"Can create clusters without the ability to set up payment methods",isAtlas:!0,atlasOnly:!0,checkFeatureFlagForVisibility:!0,sectionId:d.CLUSTER},[g.GROUP_CLUSTER_LOG_VIEWER]:{role:g.GROUP_CLUSTER_LOG_VIEWER,label:"Project Cluster Log Viewer",description:"Can view and download system logs, audit logs, and database access history without accessing cluster data",isAtlas:!0,atlasOnly:!0,checkFeatureFlagForVisibility:!0,sectionId:d.CLUSTER},[g.GROUP_CLUSTER_RESILIENCE_TESTER]:{role:g.GROUP_CLUSTER_RESILIENCE_TESTER,label:"Project Cluster Resilience Tester",description:"Can test cluster resilience and simulate failover scenarios for audit purposes",isAtlas:!0,atlasOnly:!0,checkFeatureFlagForVisibility:!0,sectionId:d.CLUSTER},[g.GROUP_SUPPORT_ACCESS_MANAGER]:{role:g.GROUP_SUPPORT_ACCESS_MANAGER,label:"Project Support Access Manager",description:"Can grant MongoDB support access to clusters and cluster logs at the project level",isAtlas:!0,atlasOnly:!0,checkFeatureFlagForVisibility:!0,sectionId:d.CLUSTER},[g.GROUP_INDEX_MANAGER]:{role:g.GROUP_INDEX_MANAGER,label:"Project Index Manager",description:"Can view Performance Advisor and create or drop rolling indexes through monitoring tools without accessing data",isAtlas:!0,atlasOnly:!0,checkFeatu